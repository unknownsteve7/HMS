# --- Environment Variables ---
# This is the most important rule. It prevents your secret keys,
# passwords, and API credentials from being committed to Git.
.env
.env.*
!.env.example

# --- Python ---
# Ignore the virtual environment folder
venv/
env/
.venv/

# Ignore Python bytecode and compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore distribution and packaging files
dist/
build/
*.egg-info/
*.egg

# --- Frontend (Node.js / React) ---
# Ignore the massive node_modules folder
node_modules/

# Ignore build output folders
build/
dist/
.next/
.nuxt/

# Ignore log files and debug output
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Log Files ---
# Ignore your server log file
server.log
*.log

# --- IDE & Editor Config ---
# Ignore configuration files from popular editors
.vscode/
.idea/
*.swp
*.swo

# --- Operating System Files ---
# Ignore macOS specific files
.DS_Store

# Ignore Windows specific files
Thumbs.db
